+// Special code to apply quirks for the Salina xhci
+#include <linux/pci.h>
+#include <linux/io.h>
+#include <linux/usb.h>
+#include <linux/usb/hcd.h>
+#include "xhci.h"
+
+#define PCI_VENDOR_ID_SONY						0x104d
+#define PCI_DEVICE_ID_PS5_SALINA_GLUE			0x9107
+#define PCI_DEVICE_ID_PS5_SALINA_XHCI			0x9108
+
+#define SALINA_GLUE_BAR2        0x85200000
+#define SALINA_GLUE_BAR2_SIZE   0x190000
+#define SALINA_GLUE_BAR3        0x85400000
+#define SALINA_GLUE_BAR3_SIZE   0x200000
+
+#define SALINA_XHCI_BAR        0x85600000
+#define SALINA_XHCI_BAR_SIZE   0x140000
+
+void __iomem * map_bar(resource_size_t phys_addr, unsigned long size);
+int init_bars(struct pci_dev *own_pdev);
+void unmap_bars(void);
+u32 phys_readl(u64 addr);
+u8 usb_get_length(u8 usb_n);
+u32 salina_glue_bar2_read(u32 addr);
+void salina_glue_bar2_write(u32 addr, u32 val);
+u32 salina_glue_usb_phy_bar2_reg_read(u32 reg);
+void salina_glue_usb_phy_bar2_reg_write(u32 reg, u32 val);
+u32 salina_glue_bar3_read(u32 addr);
+void salina_glue_bar3_write(u32 addr, u32 val);
+u32 salina_glue_usb_phy_bar3_reg_read(u32 reg);
+void salina_glue_usb_phy_bar3_reg_write(u32 reg, u32 val);
+u32 salina_xhci_bar_reg_read(u64 offset, u32 reg);
+void salina_xhci_bar_reg_write(u64 offset, u32 reg, u32 val);
+int salina_usb_phy_config_step_1(u8 usb_n);
+int salina_usb_phy_config_step_2(u8 usb_n);
+int salina_usb_phy_config_step_3(u8 usb_n);
+int salina_usb_phy_config_step_4(void);
+int xhci_salina_reset(struct xhci_hcd *xhci, u64 timeout_us);
+int xhci_salina_init(struct pci_dev *pdev);
+void xhci_salina_exit(void);
