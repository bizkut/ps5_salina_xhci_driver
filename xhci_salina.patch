diff --git a/drivers/usb/host/xhci-ps5.c b/drivers/usb/host/xhci-ps5.c
new file mode 100644
index 000000000000..7bbf4ab3e0a8
--- /dev/null
+++ b/drivers/usb/host/xhci-ps5.c
@@ -0,0 +1,499 @@
+// Special code to apply quirks for the Salina xhci
+#include <linux/pci.h>
+#include <linux/io.h>
+#include <linux/usb.h>
+#include <linux/usb/hcd.h>
+#include <asm/delay.h>
+#include "xhci-ps5.h"
+#include "xhci.h"
+#include "xhci-trace.h"
+
+#define PCI_VENDOR_ID_SONY						0x104d
+#define PCI_DEVICE_ID_PS5_SALINA_GLUE			0x9107
+#define PCI_DEVICE_ID_PS5_SALINA_XHCI			0x9108
+
+#define SALINA_GLUE_BAR2        0x85200000
+#define SALINA_GLUE_BAR2_SIZE   0x190000
+#define SALINA_GLUE_BAR3        0x85400000
+#define SALINA_GLUE_BAR3_SIZE   0x200000
+
+#define SALINA_XHCI_BAR        0x85600000
+#define SALINA_XHCI_BAR_SIZE   0x140000
+
+void __iomem * bar_salina_glue_2;
+void __iomem * bar_salina_glue_3;
+void __iomem * bar_salina_xhci;
+
+// Used on another function
+u32 salina_revision;
+
+void __iomem * map_bar(resource_size_t phys_addr, unsigned long size) {
+    void __iomem *ptr = ioremap(phys_addr, size);
+    if (!ptr) {
+        pr_err("Could not ioremap memory\n");
+        release_mem_region(phys_addr, size);
+        return 0;
+    }
+    printk("Mapped BAR %016llx with handler %p\n", phys_addr, ptr);
+    return ptr;
+}
+
+int init_bars(struct pci_dev *own_pdev) {
+
+    // We get the salina_glue BARs from PCIE device
+    struct pci_dev *remote_pdev = pci_get_device(PCI_VENDOR_ID_SONY, PCI_DEVICE_ID_PS5_SALINA_GLUE, NULL);
+    if (!remote_pdev) return -ENODEV;
+
+    resource_size_t phys_addr = pci_resource_start(remote_pdev, 2); //BAR 2
+    resource_size_t bar_len   = pci_resource_len(remote_pdev, 2);
+	printk("What i get from Salina Glue BAR2 PA %016llx LEN %016llx\n", phys_addr, bar_len);
+    if (phys_addr == 0) {
+        pci_dev_put(remote_pdev);
+        return -EINVAL;
+    }
+    bar_salina_glue_2 = map_bar(phys_addr, SALINA_GLUE_BAR2_SIZE);
+    if (!bar_salina_glue_2) return -ENOMEM;
+
+    phys_addr = pci_resource_start(remote_pdev, 4); //BAR 4
+    bar_len   = pci_resource_len(remote_pdev, 4);
+	printk("What i get from Salina Glue BAR4 PA %016llx LEN %016llx\n", phys_addr, bar_len);
+    if (phys_addr == 0) {
+        pci_dev_put(remote_pdev);
+        return -EINVAL;
+    }
+    bar_salina_glue_3 = map_bar(phys_addr, SALINA_GLUE_BAR3_SIZE);
+    if (!bar_salina_glue_3) goto err_glue2;
+
+
+    phys_addr = pci_resource_start(own_pdev, 0); //BAR0
+    bar_len   = pci_resource_len(own_pdev, 1);
+    printk("What i get from Own BAR0 PA %016llx LEN %016llx\n", phys_addr, bar_len);
+	if (phys_addr == 0) {
+        pci_dev_put(remote_pdev);
+        return -EINVAL;
+    }
+    bar_salina_xhci = map_bar(phys_addr, SALINA_XHCI_BAR_SIZE);
+    if (!bar_salina_xhci) goto err_glue3;
+
+    return 0;
+
+err_glue3:
+    iounmap(bar_salina_glue_3);
+err_glue2:
+    iounmap(bar_salina_glue_2);
+    return -ENOMEM;
+}
+
+void unmap_bars(void) {
+    iounmap(bar_salina_glue_2);
+    iounmap(bar_salina_glue_3);
+    iounmap(bar_salina_xhci);
+}
+
+u32 phys_readl(u64 addr) {
+    void __iomem *ptr = ioremap(addr, 4);
+    if (!ptr) {
+        pr_err("Could not ioremap memory\n");
+        return 0;
+    }
+    u32 val = readl(ptr);
+    printk("Read from phys %016llx : %08x\n", addr, val);
+    iounmap(ptr);
+    return val;
+}
+
+u8 usb_get_length(u8 usb_n) {
+    return (u8)((phys_readl(0x9bf44) >> (usb_n*8))&0x1f);
+}
+
+u32 salina_glue_bar2_read(u32 addr) {
+    u32 val32 = readl(bar_salina_glue_2 + addr);
+    printk("salina_glue_usb_phy_bar2_reg_read from addr %016x : %08x\n", addr, val32);
+    return val32;
+}
+
+void salina_glue_bar2_write(u32 addr, u32 val) {
+    if (!bar_salina_glue_2) return; 
+    printk("salina_glue_usb_phy_bar2_reg_write to addr %08x : %08x\n", addr, val);
+    writel(val, bar_salina_glue_2 + addr);
+    u32 val32 = readl(bar_salina_glue_2 + addr);
+    printk("salina_glue_usb_phy_bar2_reg_write from addr %08x : %08x\n", addr, val32);
+}
+
+u32 salina_glue_usb_phy_bar2_reg_read(u32 reg) {
+    u32 val32 = readl(bar_salina_glue_2 + 0x180000 + reg);
+    printk("salina_glue_usb_phy_bar2_reg_read from reg %08x : %08x\n", reg, val32);
+    return val32;
+}
+
+void salina_glue_usb_phy_bar2_reg_write(u32 reg, u32 val) {
+    if (!bar_salina_glue_2) return; 
+    printk("salina_glue_usb_phy_bar2_reg_write to reg %08x : %08x\n", reg, val);
+    writel(val, bar_salina_glue_2 + 0x180000 + reg);
+    u32 val32 = readl(bar_salina_glue_2 + 0x180000 + reg);
+    printk("salina_glue_usb_phy_bar2_reg_write from reg %08x : %08x\n", reg, val32);
+}
+
+u32 salina_glue_bar3_read(u32 addr) {
+    u32 val32 = readl(bar_salina_glue_3 + addr);
+    printk("salina_glue_bar3_reg from addr %08x : %08x\n", addr, val32);
+    return val32;
+}
+
+void salina_glue_bar3_write(u32 addr, u32 val) {
+    if (!bar_salina_glue_3) return;
+    printk("salina_glue_bar3_write to reg %08x : %08x\n", addr, val);
+    writel(val, bar_salina_glue_3 + addr);
+    u32 val32 = readl(bar_salina_glue_3 + addr);
+    printk("salina_glue_bar3_write from reg %08x : %08x\n", addr, val32);
+}
+
+u32 salina_glue_usb_phy_bar3_reg_read(u32 reg) {
+    u32 val32 = readl(bar_salina_glue_3 + 0x4000 + reg);
+    printk("salina_glue_usb_phy_bar3_reg_read from reg %08x : %08x\n", reg, val32);
+    return val32;
+}
+
+void salina_glue_usb_phy_bar3_reg_write(u32 reg, u32 val) {
+    if (!bar_salina_glue_3) return;
+    printk("salina_glue_usb_phy_bar3_reg_write to reg %08x : %08x\n", reg, val);
+    writel(val, bar_salina_glue_3 + 0x4000 + reg);
+    u32 val32 = readl(bar_salina_glue_3 + 0x4000 + reg);
+    printk("salina_glue_usb_phy_bar3_reg_write from reg %08x : %08x\n", reg, val32);
+}
+
+u32 salina_xhci_bar_reg_read(u64 offset, u32 reg) {
+    printk("salina_xhci_bar_reg_read offset: %016llx reg: %08x\n", offset, reg);
+    u32 val32 = readl(bar_salina_xhci + offset + reg);
+    printk("Read value: %08x\n", val32);
+    return val32;
+}
+
+void salina_xhci_bar_reg_write(u64 offset, u32 reg, u32 val) {
+    if (!bar_salina_xhci) return; 
+    printk("salina_xhci_bar_reg_write offset: %016llx reg: %08x val: %08x\n", offset, reg, val);
+    writel(val, bar_salina_xhci + offset + reg);
+    u32 val32 = readl(bar_salina_xhci + offset + reg);
+    printk("salina_xhci_bar_reg_write from reg %08x : %08x\n", reg, val32);
+}
+
+int salina_usb_phy_config_step_1(u8 usb_n) {
+
+    u64 bar_offset;
+    u32 val32;
+    u32 usb_efuse;
+    u32 usb_length;
+
+    switch (usb_n) {
+        case 0: bar_offset = 0x120000; break;
+        case 1: bar_offset = 0x124000; break;
+        case 2: bar_offset = 0x128000; break;
+        default: bar_offset = 0x120000;
+    }
+
+    val32 = salina_glue_usb_phy_bar3_reg_read(0x6c);
+    if ((val32 >> 0x19 & val32 >> 0x11 & 1) == 0) {
+        printk("[USB%d] eFuse not blown for usb\n", usb_n);
+        usb_efuse = 0x98;
+    }
+    else {
+        usb_efuse = (salina_glue_usb_phy_bar3_reg_read(0x44) >> (usb_n*5+0x10)) & 0x1f;
+    }
+    printk("This is the value of USB%d fuse: %05x\n", usb_n, usb_efuse);
+
+	salina_xhci_bar_reg_write(bar_offset, 0x800, 0x480a);
+
+    salina_xhci_bar_reg_write(bar_offset, 0x814, 0x10a01000);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x818);
+    salina_xhci_bar_reg_write(bar_offset, 0x818, val32 & 0xff7fffff);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x800);
+    salina_xhci_bar_reg_write(bar_offset, 0x800, val32 | 0x20);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x868);
+    salina_xhci_bar_reg_write(bar_offset, 0x868, val32 & 0xfffbffff);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x804);
+    salina_xhci_bar_reg_write(bar_offset, 0x804, (val32 & 0xff07ffff) | (usb_efuse<<0x13));
+
+    usb_length = usb_get_length(usb_n);
+    printk("This is the value of USB%d usb_length: %05x\n", usb_n, usb_length);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x818);
+    salina_xhci_bar_reg_write(bar_offset, 0x818, (val32 & 0xffffff0f) | 0xa0);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x818);
+
+    if (usb_length < 3)
+        salina_xhci_bar_reg_write(bar_offset, 0x818, (val32 & 0xfffffff0) | 8);
+    else if (usb_length < 6)
+        salina_xhci_bar_reg_write(bar_offset, 0x818, (val32 & 0xfffffff0) | 7);
+    else if (usb_length < 8)
+        salina_xhci_bar_reg_write(bar_offset, 0x818, (val32 & 0xfffffff0) | 6);
+    else if (usb_length < 10)
+        salina_xhci_bar_reg_write(bar_offset, 0x818, (val32 & 0xfffffff0) | 5);
+    else if (usb_length < 13)
+        salina_xhci_bar_reg_write(bar_offset, 0x818, (val32 & 0xfffffff0) | 4);
+    else {
+        // Default values
+        switch (usb_n) {
+            case 0: salina_xhci_bar_reg_write(bar_offset, 0x818, (val32 & 0xfffffff0) | 4); break;
+            case 1: salina_xhci_bar_reg_write(bar_offset, 0x818, (val32 & 0xfffffff0) | 6); break;
+            case 2: salina_xhci_bar_reg_write(bar_offset, 0x818, (val32 & 0xfffffff0) | 7); break;
+        }
+    }
+
+    return 0;
+}
+
+int salina_usb_phy_config_step_2(u8 usb_n) {
+
+    u64 bar_offset;
+    u32 val32;
+
+    switch (usb_n) {
+        case 0: bar_offset = 0x120000; break;
+        case 1: bar_offset = 0x124000; break;
+        case 2: bar_offset = 0x128000; break;
+        default: bar_offset = 0x120000;
+    }
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x814);
+    salina_xhci_bar_reg_write(bar_offset, 0x814, val32 | 0x8000);
+
+    usleep_range(1,2);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x110);
+    salina_xhci_bar_reg_write(bar_offset, 0x110, val32 | 0x100);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x100);
+    salina_xhci_bar_reg_write(bar_offset, 0x100, (val32 & 0xff000000) | 0x400);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x100);
+    salina_xhci_bar_reg_write(bar_offset, 0x100, val32 | 0x1000000);
+
+    int attemps = 100;
+    u32 measure;
+    do {
+        measure = salina_xhci_bar_reg_read(bar_offset, 0x10c);
+        usleep_range(1,2);
+        if (measure!=0) break;
+        attemps--;
+    } while(attemps!=0);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x100);
+    salina_xhci_bar_reg_write(bar_offset, 0x100, val32 & 0xfeffffff);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x110);
+    salina_xhci_bar_reg_write(bar_offset, 0x110, val32 & 0xfffffeff);
+
+    if (!measure) {
+        printk("Something went wrong while waiting for USB init\n");
+        return -1;
+    }
+    // usb2 TX slew rate calibration
+    u32 calibration = (u32)((0xb9000 / (u64)measure) / 1000);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x814);
+    salina_xhci_bar_reg_write(bar_offset, 0x814, (val32 & 0xffff8fff) | (calibration<<12));
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x814);
+    salina_xhci_bar_reg_write(bar_offset, 0x814, val32 & 0xffff7fff);
+
+    return 0;
+}
+
+int salina_usb_phy_config_step_3(u8 usb_n) {
+
+    u64 bar_offset;
+    u32 val32;
+
+    switch (usb_n) {
+        case 0: bar_offset = 0x120000; break;
+        case 1: bar_offset = 0x124000; break;
+        case 2: bar_offset = 0x128000; break;
+        default: bar_offset = 0x120000;
+    }
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x800);
+    salina_xhci_bar_reg_write(bar_offset, 0x800, val32 | 0x1);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x808);
+    salina_xhci_bar_reg_write(bar_offset, 0x808, val32 & 0xfffdffff);
+
+    val32 = salina_xhci_bar_reg_read(bar_offset, 0x880);
+    salina_xhci_bar_reg_write(bar_offset, 0x880, val32 | 0x1);
+
+    return 0;
+}
+
+int salina_usb_phy_config_step_4(void) {
+    u32 val32 = salina_xhci_bar_reg_read(0, 0xc100);
+    salina_xhci_bar_reg_write(0, 0xc100, (val32 & 0xfffffff0) | 0xe);
+    salina_xhci_bar_reg_write(0, 0xc12c, 0x7fc0c010);
+    salina_xhci_bar_reg_write(0, 0xc200, 0x1548);
+    salina_xhci_bar_reg_write(0, 0xc204, 0x1548);
+    salina_xhci_bar_reg_write(0, 0xc208, 0x1548);
+    return 0;
+}
+
+int xhci_salina_reset(struct xhci_hcd *xhci, u64 timeout_us) {
+
+    printk("Enter xhci_salina_reset()\n");
+
+	u32 command;
+	u32 state;
+	int ret;
+
+    command = salina_xhci_bar_reg_read(0x100000, 0x0);
+    salina_xhci_bar_reg_write(0x100000, 0x0, command & 0xfffffffb);   // Disable bit2
+
+
+	state = readl(&xhci->op_regs->status);
+
+	if (state == ~(u32)0) {
+		if (!(xhci->xhc_state & XHCI_STATE_DYING))
+			xhci_warn(xhci, "Host not accessible, reset failed.\n");
+		return -ENODEV;
+	}
+
+	if ((state & STS_HALT) == 0) {
+		xhci_warn(xhci, "Host controller not halted, aborting reset.\n");
+		return 0;
+	}
+
+	printk("// Reset the HC on custom Salina Reset");
+	writel(CMD_RESET, &xhci->op_regs->command);
+
+    udelay(1000);
+
+    ret = xhci_handshake(&xhci->op_regs->command, CMD_RESET, 0, timeout_us);
+	if (ret)
+		return ret;
+
+    printk("Wait for controller to be ready for doorbell rings");
+    ret = xhci_handshake(&xhci->op_regs->status, STS_CNR, 0, timeout_us);
+	if (ret)
+		return ret;
+
+    // Now custom part
+    command = salina_xhci_bar_reg_read(0x100000, 0x0);
+    salina_xhci_bar_reg_write(0x100000, 0x0, command | 0x2);        // Enable  bit1
+    salina_xhci_bar_reg_write(0x100000, 0x0, command & 0xfffffffd); // Disable bit1
+
+    command = salina_xhci_bar_reg_read(0x100000, 0x0);
+    salina_xhci_bar_reg_write(0x100000, 0x0, command | 0x20000);    // Enable  bit17
+    salina_xhci_bar_reg_write(0x100000, 0x0, command & 0xfffdffff); // Disable bit17
+
+    command = salina_xhci_bar_reg_read(0x100000, 0x0);
+    salina_xhci_bar_reg_write(0x100000, 0x0, command | 0x2000000);  // Enable  bit25
+    salina_xhci_bar_reg_write(0x100000, 0x0, command & 0xfdffffff); // Disable bit25
+
+    udelay(10000);
+    udelay(10000);
+    udelay(10000);
+
+    command = salina_xhci_bar_reg_read(0x100000, 0x0);
+    salina_xhci_bar_reg_write(0x100000, 0x0, command & 0xfffffffd); // Enable  bit1
+
+    udelay(10000);
+    udelay(10000);
+
+    command = salina_xhci_bar_reg_read(0x100000, 0x0);
+    salina_xhci_bar_reg_write(0x100000, 0x0, command | 4);          // Enable  bit2
+
+    udelay(10000);
+    udelay(10000);
+
+    salina_usb_phy_config_step_4();
+
+	#define OPER_BAR 0x20
+
+	u32 usbcmd  = salina_xhci_bar_reg_read(OPER_BAR, 0x00);
+	u32 usbsts  = salina_xhci_bar_reg_read(OPER_BAR, 0x04);
+	u32 dnctrl  = salina_xhci_bar_reg_read(OPER_BAR, 0x14);
+	u32 config  = salina_xhci_bar_reg_read(OPER_BAR, 0x38);
+	u32 crcr_lo = salina_xhci_bar_reg_read(OPER_BAR, 0x18);
+	u32 crcr_hi = salina_xhci_bar_reg_read(OPER_BAR, 0x1c);
+
+	printk("USBCMD=%08x USBSTS=%08x DNCTRL=%08x CONFIG=%08x CRCR=%08x%08x\n",
+	       usbcmd, usbsts, dnctrl, config, crcr_hi, crcr_lo);
+
+
+    u32 c100 = salina_xhci_bar_reg_read(0x0, 0xc100);
+    u32 c12c = salina_xhci_bar_reg_read(0x0, 0xc12c);
+    u32 c200 = salina_xhci_bar_reg_read(0x0, 0xc200);
+    u32 c204 = salina_xhci_bar_reg_read(0x0, 0xc204);
+    u32 c208 = salina_xhci_bar_reg_read(0x0, 0xc208);
+
+    printk("SALINA PWR: c100=%08x c12c=%08x c200=%08x c204=%08x c208=%08x\n",
+           c100, c12c, c200, c204, c208);
+
+    // Reset software state
+    xhci->usb2_rhub.bus_state.port_c_suspend = 0;
+	xhci->usb2_rhub.bus_state.suspended_ports = 0;
+	xhci->usb2_rhub.bus_state.resuming_ports = 0;
+	xhci->usb3_rhub.bus_state.port_c_suspend = 0;
+	xhci->usb3_rhub.bus_state.suspended_ports = 0;
+	xhci->usb3_rhub.bus_state.resuming_ports = 0;
+
+    return 0;
+}
+
+int xhci_salina_init(struct pci_dev *pdev) {
+
+    int ret;
+    u32 val32;
+
+    printk("\n\n\n***** Module salina_usb_phy_init loaded *****\n");
+
+    ret = init_bars(pdev);
+    if (ret) {
+        pr_err("could not map BARs\n");
+        return ret; // Esto evita el refcount: 1
+    }
+
+    printk("Now trying to setup xhci Salina\n");
+
+    val32 = salina_glue_usb_phy_bar2_reg_read(0x24);
+    salina_glue_usb_phy_bar2_reg_write(0x24, val32|2);
+
+    val32 = salina_glue_usb_phy_bar2_reg_read(0x24);
+    salina_glue_usb_phy_bar2_reg_write(0x24, val32|1);
+
+    // Start Config Bit 2
+    val32 = salina_glue_usb_phy_bar2_reg_read(0x24);
+    salina_glue_usb_phy_bar2_reg_write(0x24, val32 & 0xfffffffd);
+
+    if(salina_usb_phy_config_step_1(0)) return -1;
+    if(salina_usb_phy_config_step_1(1)) return -1;
+    if(salina_usb_phy_config_step_1(2)) return -1;
+
+    // Start Config Bit 1
+    val32 = salina_glue_usb_phy_bar2_reg_read(0x24);
+    salina_glue_usb_phy_bar2_reg_write(0x24, val32 & 0xfffffffe);
+
+    // Wait for init
+    udelay(2000);
+
+    if(salina_usb_phy_config_step_2(0)) return -1;
+    if(salina_usb_phy_config_step_2(1)) return -1;
+    if(salina_usb_phy_config_step_2(2)) return -1;
+
+    if(salina_usb_phy_config_step_3(0)) return -1;
+    if(salina_usb_phy_config_step_3(1)) return -1;
+    if(salina_usb_phy_config_step_3(2)) return -1;
+
+    val32 = salina_xhci_bar_reg_read(0x100000, 0x4);
+    salina_xhci_bar_reg_write(0x100000, 0x4, val32 & 0xfffffffe);
+
+    salina_usb_phy_config_step_4();
+
+    return 0;
+}
+
+void xhci_salina_exit(void)
+{
+    unmap_bars();
+}
