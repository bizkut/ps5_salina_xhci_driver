diff --git a/drivers/usb/host/xhci-ps5.c b/drivers/usb/host/xhci-ps5.c
new file mode 100644
index 000000000000..111111111111
--- /dev/null
+++ b/drivers/usb/host/xhci-ps5.c
@@ -0,0 +1,525 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Sony PlayStation 5 Salina xHCI glue and PHY setup.
+ */
+
+#define pr_fmt(fmt) KBUILD_MODNAME ": " fmt
+
+#include <linux/delay.h>
+#include <linux/io.h>
+#include <linux/pci.h>
+#include <linux/usb.h>
+#include <linux/usb/hcd.h>
+#include <linux/workqueue.h>
+
+#include "xhci.h"
+#include "xhci-ps5.h"
+#include "xhci-ring.h"
+
+#define PCI_DEVICE_ID_PS5_SALINA_GLUE	0x9107
+
+#define SALINA_GLUE_BAR2_PHY_BASE	0x180000
+#define SALINA_GLUE_BAR4_PHY_BASE	0x4000
+#define SALINA_XHCI_PHY0_BASE		0x120000
+#define SALINA_XHCI_PHY_STRIDE		0x4000
+#define SALINA_XHCI_CTRL_BASE		0x100000
+#define SALINA_USB_TRACE_LEN_PHYS	0x9bf44
+
+#define SALINA_MIN_GLUE_BAR2_SIZE	0x180028
+#define SALINA_MIN_GLUE_BAR4_SIZE	0x4070
+#define SALINA_MIN_XHCI_BAR_SIZE		0x129000
+#define SALINA_POLL_INTERVAL_MS		100
+
+struct salina_xhci_state {
+	struct pci_dev *glue;
+	void __iomem *glue_bar2;
+	void __iomem *glue_bar4;
+	void __iomem *xhci_bar;
+};
+
+struct salina_xhci_poller {
+	struct xhci_hcd *xhci;
+	struct delayed_work work;
+	bool running;
+};
+
+static struct salina_xhci_state salina;
+static struct salina_xhci_poller salina_poll;
+
+static int salina_ioremap_bar(struct pci_dev *pdev, int bar,
+				      resource_size_t min_size, void __iomem **base)
+{
+	resource_size_t start = pci_resource_start(pdev, bar);
+	resource_size_t len = pci_resource_len(pdev, bar);
+
+	if (!(pci_resource_flags(pdev, bar) & IORESOURCE_MEM) || !start ||
+	    len < min_size)
+		return -ENODEV;
+
+	*base = ioremap(start, len);
+	return *base ? 0 : -ENOMEM;
+}
+
+static void salina_unmap_bars(void)
+{
+	if (salina.xhci_bar) {
+		iounmap(salina.xhci_bar);
+		salina.xhci_bar = NULL;
+	}
+
+	if (salina.glue_bar4) {
+		iounmap(salina.glue_bar4);
+		salina.glue_bar4 = NULL;
+	}
+
+	if (salina.glue_bar2) {
+		iounmap(salina.glue_bar2);
+		salina.glue_bar2 = NULL;
+	}
+
+	if (salina.glue) {
+		pci_dev_put(salina.glue);
+		salina.glue = NULL;
+	}
+}
+
+static int salina_map_bars(struct pci_dev *pdev)
+{
+	int ret;
+
+	salina.glue = pci_get_device(PCI_VENDOR_ID_SONY,
+					 PCI_DEVICE_ID_PS5_SALINA_GLUE, NULL);
+	if (!salina.glue)
+		return -ENODEV;
+
+	ret = salina_ioremap_bar(salina.glue, 2, SALINA_MIN_GLUE_BAR2_SIZE,
+				       &salina.glue_bar2);
+	if (ret)
+		goto err_unmap;
+
+	ret = salina_ioremap_bar(salina.glue, 4, SALINA_MIN_GLUE_BAR4_SIZE,
+				       &salina.glue_bar4);
+	if (ret)
+		goto err_unmap;
+
+	ret = salina_ioremap_bar(pdev, 0, SALINA_MIN_XHCI_BAR_SIZE,
+				       &salina.xhci_bar);
+	if (ret)
+		goto err_unmap;
+
+	return 0;
+
+err_unmap:
+	salina_unmap_bars();
+	return ret;
+}
+
+static u32 salina_phys_readl(phys_addr_t addr)
+{
+	void __iomem *ptr;
+	u32 val;
+
+	ptr = ioremap(addr, sizeof(u32));
+	if (!ptr)
+		return 0;
+
+	val = readl(ptr);
+	iounmap(ptr);
+	return val;
+}
+
+static u8 salina_usb_trace_len(u8 port)
+{
+	return (salina_phys_readl(SALINA_USB_TRACE_LEN_PHYS) >> (port * 8)) & 0x1f;
+}
+
+static u32 salina_glue_phy_read(u32 reg)
+{
+	return readl(salina.glue_bar2 + SALINA_GLUE_BAR2_PHY_BASE + reg);
+}
+
+static void salina_glue_phy_write(u32 reg, u32 val)
+{
+	writel(val, salina.glue_bar2 + SALINA_GLUE_BAR2_PHY_BASE + reg);
+}
+
+static u32 salina_glue_pcs_read(u32 reg)
+{
+	return readl(salina.glue_bar4 + SALINA_GLUE_BAR4_PHY_BASE + reg);
+}
+
+static u32 salina_xhci_read(u32 offset, u32 reg)
+{
+	return readl(salina.xhci_bar + offset + reg);
+}
+
+static void salina_xhci_write(u32 offset, u32 reg, u32 val)
+{
+	writel(val, salina.xhci_bar + offset + reg);
+}
+
+static int salina_usb_phy_base(u8 port, u32 *base)
+{
+	if (port > 2)
+		return -EINVAL;
+
+	*base = SALINA_XHCI_PHY0_BASE + port * SALINA_XHCI_PHY_STRIDE;
+	return 0;
+}
+
+static u8 salina_usb_trace_trim(u8 port, u8 trace_len)
+{
+	if (trace_len < 3)
+		return 8;
+	if (trace_len < 6)
+		return 7;
+	if (trace_len < 8)
+		return 6;
+	if (trace_len < 10)
+		return 5;
+	if (trace_len < 13)
+		return 4;
+
+	switch (port) {
+	case 0:
+		return 4;
+	case 1:
+		return 6;
+	case 2:
+		return 7;
+	default:
+		return 4;
+	}
+}
+
+static int salina_usb_phy_config_step_1(u8 port)
+{
+	u32 base;
+	u32 val;
+	u32 efuse;
+	u8 trace_len;
+	int ret;
+
+	ret = salina_usb_phy_base(port, &base);
+	if (ret)
+		return ret;
+
+	val = salina_glue_pcs_read(0x6c);
+	if (!((val >> 0x19) & (val >> 0x11) & 1))
+		efuse = 0x98;
+	else
+		efuse = (salina_glue_pcs_read(0x44) >> (port * 5 + 0x10)) & 0x1f;
+
+	salina_xhci_write(base, 0x800, 0x480a);
+	salina_xhci_write(base, 0x814, 0x10a01000);
+
+	val = salina_xhci_read(base, 0x818);
+	salina_xhci_write(base, 0x818, val & 0xff7fffff);
+
+	val = salina_xhci_read(base, 0x800);
+	salina_xhci_write(base, 0x800, val | 0x20);
+
+	val = salina_xhci_read(base, 0x868);
+	salina_xhci_write(base, 0x868, val & 0xfffbffff);
+
+	val = salina_xhci_read(base, 0x804);
+	salina_xhci_write(base, 0x804, (val & 0xff07ffff) | (efuse << 0x13));
+
+	trace_len = salina_usb_trace_len(port);
+	val = salina_xhci_read(base, 0x818);
+	salina_xhci_write(base, 0x818, (val & 0xffffff0f) | 0xa0);
+
+	val = salina_xhci_read(base, 0x818);
+	salina_xhci_write(base, 0x818,
+			   (val & 0xfffffff0) | salina_usb_trace_trim(port, trace_len));
+
+	return 0;
+}
+
+static int salina_usb_phy_config_step_2(u8 port)
+{
+	u32 base;
+	u32 calibration;
+	u32 measure = 0;
+	u32 val;
+	int attempts = 100;
+	int ret;
+
+	ret = salina_usb_phy_base(port, &base);
+	if (ret)
+		return ret;
+
+	val = salina_xhci_read(base, 0x814);
+	salina_xhci_write(base, 0x814, val | 0x8000);
+
+	usleep_range(1, 2);
+
+	val = salina_xhci_read(base, 0x110);
+	salina_xhci_write(base, 0x110, val | 0x100);
+
+	val = salina_xhci_read(base, 0x100);
+	salina_xhci_write(base, 0x100, (val & 0xff000000) | 0x400);
+
+	val = salina_xhci_read(base, 0x100);
+	salina_xhci_write(base, 0x100, val | 0x1000000);
+
+	do {
+		measure = salina_xhci_read(base, 0x10c);
+		if (measure)
+			break;
+		usleep_range(1, 2);
+	} while (--attempts);
+
+	val = salina_xhci_read(base, 0x100);
+	salina_xhci_write(base, 0x100, val & 0xfeffffff);
+
+	val = salina_xhci_read(base, 0x110);
+	salina_xhci_write(base, 0x110, val & 0xfffffeff);
+
+	if (!measure)
+		return -ETIMEDOUT;
+
+	calibration = (u32)((0xb9000 / (u64)measure) / 1000);
+
+	val = salina_xhci_read(base, 0x814);
+	salina_xhci_write(base, 0x814, (val & 0xffff8fff) | (calibration << 12));
+
+	val = salina_xhci_read(base, 0x814);
+	salina_xhci_write(base, 0x814, val & 0xffff7fff);
+
+	return 0;
+}
+
+static int salina_usb_phy_config_step_3(u8 port)
+{
+	u32 base;
+	u32 val;
+	int ret;
+
+	ret = salina_usb_phy_base(port, &base);
+	if (ret)
+		return ret;
+
+	val = salina_xhci_read(base, 0x800);
+	salina_xhci_write(base, 0x800, val | 0x1);
+
+	val = salina_xhci_read(base, 0x808);
+	salina_xhci_write(base, 0x808, val & 0xfffdffff);
+
+	val = salina_xhci_read(base, 0x880);
+	salina_xhci_write(base, 0x880, val | 0x1);
+
+	return 0;
+}
+
+static void salina_usb_phy_config_step_4(void)
+{
+	u32 val;
+
+	val = salina_xhci_read(0, 0xc100);
+	salina_xhci_write(0, 0xc100, (val & 0xfffffff0) | 0xe);
+	salina_xhci_write(0, 0xc12c, 0x7fc0c010);
+	salina_xhci_write(0, 0xc200, 0x1548);
+	salina_xhci_write(0, 0xc204, 0x1548);
+	salina_xhci_write(0, 0xc208, 0x1548);
+}
+
+static void salina_xhci_toggle(u32 reg, u32 bit)
+{
+	u32 command = salina_xhci_read(SALINA_XHCI_CTRL_BASE, reg);
+
+	salina_xhci_write(SALINA_XHCI_CTRL_BASE, reg, command | bit);
+	salina_xhci_write(SALINA_XHCI_CTRL_BASE, reg, command & ~bit);
+}
+
+int xhci_salina_reset(struct xhci_hcd *xhci, u64 timeout_us)
+{
+	u32 command;
+	u32 state;
+	int ret;
+
+	command = salina_xhci_read(SALINA_XHCI_CTRL_BASE, 0x0);
+	salina_xhci_write(SALINA_XHCI_CTRL_BASE, 0x0, command & ~BIT(2));
+
+	state = readl(&xhci->op_regs->status);
+	if (state == ~(u32)0) {
+		if (!(xhci->xhc_state & XHCI_STATE_DYING))
+			xhci_warn(xhci, "Host not accessible, reset failed.\n");
+		return -ENODEV;
+	}
+
+	if ((state & STS_HALT) == 0) {
+		xhci_warn(xhci, "Host controller not halted, aborting reset.\n");
+		return 0;
+	}
+
+	writel(CMD_RESET, &xhci->op_regs->command);
+	udelay(1000);
+
+	ret = xhci_handshake(&xhci->op_regs->command, CMD_RESET, 0, timeout_us);
+	if (ret)
+		return ret;
+
+	ret = xhci_handshake(&xhci->op_regs->status, STS_CNR, 0, timeout_us);
+	if (ret)
+		return ret;
+
+	salina_xhci_toggle(0x0, BIT(1));
+	salina_xhci_toggle(0x0, BIT(17));
+	salina_xhci_toggle(0x0, BIT(25));
+
+	usleep_range(30000, 31000);
+
+	command = salina_xhci_read(SALINA_XHCI_CTRL_BASE, 0x0);
+	salina_xhci_write(SALINA_XHCI_CTRL_BASE, 0x0, command & ~BIT(1));
+
+	usleep_range(20000, 21000);
+
+	command = salina_xhci_read(SALINA_XHCI_CTRL_BASE, 0x0);
+	salina_xhci_write(SALINA_XHCI_CTRL_BASE, 0x0, command | BIT(2));
+
+	usleep_range(20000, 21000);
+	salina_usb_phy_config_step_4();
+
+	xhci->usb2_rhub.bus_state.port_c_suspend = 0;
+	xhci->usb2_rhub.bus_state.suspended_ports = 0;
+	xhci->usb2_rhub.bus_state.resuming_ports = 0;
+	xhci->usb3_rhub.bus_state.port_c_suspend = 0;
+	xhci->usb3_rhub.bus_state.suspended_ports = 0;
+	xhci->usb3_rhub.bus_state.resuming_ports = 0;
+
+	return 0;
+}
+
+int xhci_salina_init(struct pci_dev *pdev)
+{
+	u32 val;
+	u8 port;
+	int ret;
+
+	ret = salina_map_bars(pdev);
+	if (ret)
+		return ret;
+
+	val = salina_glue_phy_read(0x24);
+	salina_glue_phy_write(0x24, val | BIT(1));
+
+	val = salina_glue_phy_read(0x24);
+	salina_glue_phy_write(0x24, val | BIT(0));
+
+	val = salina_glue_phy_read(0x24);
+	salina_glue_phy_write(0x24, val & ~BIT(1));
+
+	for (port = 0; port < 3; port++) {
+		ret = salina_usb_phy_config_step_1(port);
+		if (ret)
+			goto err_unmap;
+	}
+
+	val = salina_glue_phy_read(0x24);
+	salina_glue_phy_write(0x24, val & ~BIT(0));
+
+	udelay(2000);
+
+	for (port = 0; port < 3; port++) {
+		ret = salina_usb_phy_config_step_2(port);
+		if (ret)
+			goto err_unmap;
+	}
+
+	for (port = 0; port < 3; port++) {
+		ret = salina_usb_phy_config_step_3(port);
+		if (ret)
+			goto err_unmap;
+	}
+
+	val = salina_xhci_read(SALINA_XHCI_CTRL_BASE, 0x4);
+	salina_xhci_write(SALINA_XHCI_CTRL_BASE, 0x4, val & ~BIT(0));
+
+	salina_usb_phy_config_step_4();
+	dev_info(&pdev->dev, "PS5 Salina xHCI PHY initialized\n");
+	return 0;
+
+err_unmap:
+	salina_unmap_bars();
+	return ret;
+}
+
+void xhci_salina_exit(void)
+{
+	salina_unmap_bars();
+}
+
+static bool salina_event_pending(struct xhci_ring *ring)
+{
+	struct xhci_segment *seg;
+	u32 index;
+	u32 control;
+
+	if (!ring || !ring->deq_seg || !ring->dequeue)
+		return false;
+
+	seg = ring->deq_seg;
+	index = ring->dequeue - seg->trbs;
+	if (index >= TRBS_PER_SEGMENT)
+		return false;
+
+	control = le32_to_cpu(seg->trbs[index].generic.field[3]);
+	return !!((control & TRB_CYCLE) == ring->cycle_state);
+}
+
+static void salina_xhci_poll_fn(struct work_struct *work)
+{
+	struct salina_xhci_poller *poller;
+	struct xhci_hcd *xhci;
+	struct xhci_interrupter *ir;
+	unsigned long flags;
+	bool resched = true;
+
+	poller = container_of(work, struct salina_xhci_poller, work.work);
+	xhci = poller->xhci;
+	if (!poller->running || !xhci)
+		return;
+
+	if (!spin_trylock_irqsave(&xhci->lock, flags))
+		goto out_resched;
+
+	if (xhci->xhc_state & (XHCI_STATE_DYING | XHCI_STATE_REMOVING)) {
+		resched = false;
+		goto out_unlock;
+	}
+
+	ir = xhci->interrupters[0];
+	if (ir && salina_event_pending(ir->event_ring))
+		xhci_handle_events(xhci, ir, false);
+
+out_unlock:
+	spin_unlock_irqrestore(&xhci->lock, flags);
+out_resched:
+	if (resched && poller->running)
+		schedule_delayed_work(&poller->work,
+				      msecs_to_jiffies(SALINA_POLL_INTERVAL_MS));
+}
+
+void salina_start_xhci_poller(struct xhci_hcd *xhci)
+{
+	if (salina_poll.running)
+		return;
+
+	salina_poll.xhci = xhci;
+	salina_poll.running = true;
+	INIT_DELAYED_WORK(&salina_poll.work, salina_xhci_poll_fn);
+	schedule_delayed_work(&salina_poll.work,
+			      msecs_to_jiffies(SALINA_POLL_INTERVAL_MS));
+	xhci_info(xhci, "Salina software IRQ poller enabled\n");
+}
+
+void salina_stop_xhci_poller(void)
+{
+	if (!salina_poll.running)
+		return;
+
+	salina_poll.running = false;
+	cancel_delayed_work_sync(&salina_poll.work);
+	salina_poll.xhci = NULL;
+}
