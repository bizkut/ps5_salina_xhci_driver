diff --git a/drivers/usb/host/xhci-pci.c b/drivers/usb/host/xhci-pci.c
index 83af325b7..f4a98bb37 100644
--- a/drivers/usb/host/xhci-pci.c
+++ b/drivers/usb/host/xhci-pci.c
@@ -16,6 +16,7 @@
 #include "xhci.h"
 #include "xhci-trace.h"
 #include "xhci-pci.h"
+#include "xhci-ps5.h"
 
 #define SSIC_PORT_NUM		2
 #define SSIC_PORT_CFG2		0x880c
@@ -285,6 +286,10 @@ static void xhci_pci_quirks(struct device *dev, struct xhci_hcd *xhci)
 	if (pdev->vendor == PCI_VENDOR_ID_NEC)
 		xhci->quirks |= XHCI_NEC_HOST;
 
+	if (pdev->vendor == PCI_VENDOR_ID_SONY &&
+	    pdev->device == PCI_DEVICE_ID_PS5_SALINA_XHCI)
+		xhci->quirks |= XHCI_PS5_SALINA_PHY;
+
 	if (pdev->vendor == PCI_VENDOR_ID_AMD &&
 	    (pdev->device == PCI_DEVICE_ID_AMD_ARIEL_TYPEC_XHCI ||
 	     pdev->device == PCI_DEVICE_ID_AMD_ARIEL_TYPEA_XHCI ||
@@ -571,6 +577,13 @@ static int xhci_pci_setup(struct usb_hcd *hcd)
 
 	xhci = hcd_to_xhci(hcd);
 
+	if (pdev->vendor == PCI_VENDOR_ID_SONY &&
+	    pdev->device == PCI_DEVICE_ID_PS5_SALINA_XHCI) {
+		retval = xhci_salina_init(pdev);
+		if (retval)
+			return retval;
+	}
